# Copy this file to .env and fill in your values.
# Never commit the .env file (it is in .gitignore).

# Required: Google Sheets API key (same key used by poll-tracker-app).
# Enable the Sheets API in Google Cloud Console and restrict the key to your domain.
VITE_GOOGLE_SHEETS_API_KEY=your_api_key_here

# Optional: override the default spreadsheet ID.
# VITE_GOOGLE_SHEETS_SPREADSHEET_ID=1RIqzrv_ViVWBqeXkM-rOAvusoXryyRFX5Xmu2S-uEw4

# Set by CI to /Elections/media-bias/ — leave blank for local dev.
# VITE_BASE=/Elections/media-bias/
