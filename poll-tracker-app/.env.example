# ── Recommended local dev: same as GitHub Pages (browser + API key) ────
# Paste the same key as GitHub Actions secret VITE_GOOGLE_SHEETS_API_KEY.
# In GCP → Credentials → your API key → HTTP referrers, add:
#   http://localhost:5173/*
# (use your dev port if not 5173). Also keep your github.io referrers for production.
# VITE_GOOGLE_SHEETS_SPREADSHEET_ID=   # optional; default sheet ID is built into the app
VITE_GOOGLE_SHEETS_API_KEY=

# ── Fallback: Vite dev proxy (service account JWT) — only if VITE key above is empty ──
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Optional: how often to refetch sheet data in the browser (ms). Default 180000 (3 min).
# VITE_SHEETS_POLL_INTERVAL_MS=180000

# Local build that matches GitHub Pages URL (repo name Elections_Polls):
# VITE_BASE=/Elections_Polls/
