# ── Local dev: Vite proxy (service account) ─────────────────────────────
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ── Production / GitHub Pages: browser calls Google Sheets API v4 ───────
# Required on GitHub: Actions secret VITE_GOOGLE_SHEETS_API_KEY (same value as below for local prod builds).
# Optional: VITE_GOOGLE_SHEETS_SPREADSHEET_ID — if unset, the app uses the project default sheet ID.
# Create an API key in Google Cloud → APIs & Services → Credentials.
# Enable "Google Sheets API". Restrict the key with HTTP referrers, e.g. BOTH of:
#   https://YOUR_USERNAME.github.io/Elections_Polls/*
#   https://YOUR_USERNAME.github.io/*
# (Browsers often send only the origin https://YOUR_USERNAME.github.io/ for cross-origin requests,
#  which does NOT match the /Elections_Polls/* pattern unless you add the shorter line or use app build with referrerPolicy.)
# Share the spreadsheet: "Anyone with the link" → Viewer (or public).
# VITE_GOOGLE_SHEETS_SPREADSHEET_ID=
VITE_GOOGLE_SHEETS_API_KEY=

# Optional: how often to refetch sheet data in the browser (ms). Default 180000 (3 min).
# VITE_SHEETS_POLL_INTERVAL_MS=180000

# Local build that matches GitHub Pages URL (repo name Elections_Polls):
# VITE_BASE=/Elections_Polls/
